# Supabase Configuration
REACT_APP_SUPABASE_URL=https://your-project-id.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your_supabase_anon_key

# SendGrid Configuration (used by Vercel API route)
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDER_EMAIL=info@weteamup.app

# MailerLite Configuration (optional)
REACT_APP_MAILERLITE_API_KEY=your_mailerlite_api_key

# API URL (for local dev, leave empty for Vercel deployment)
REACT_APP_API_URL=

